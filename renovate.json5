{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [":pinDependencies", "config:best-practices", "customManagers:githubActionsVersions"],
  branchPrefix: "chore/renovate-",
  rebaseWhen: "behind-base-branch",
  packageRules: [
    {
      matchManagers: "github-actions",
    },
    {
      matchPackageNames: ["ghcr.io/linuxserver/*"],
      matchUpdateTypes: ["digest"],
      automerge: true,
    },
    {
      matchPackageNames: ["ghcr.io/music-assistant/server"],
      versioning: "pep440",
    },
    {
      matchManagers: ["nix"],
    },
    // Automerge patch updates.
    {
      matchUpdateTypes: ["patch"],
      automerge: true,
    },
    // Automerge minor updates for non 0.x.x versions.
    {
      matchUpdateTypes: ["minor"],
      matchCurrentVersion: "!/^0/",
      automerge: true,
    },
  ],
  customManagers: [
    // Docker images defined in Terraform files (as Helm values).
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)*\\.tf$/"],
      datasourceTemplate: "docker",
      matchStrings: ['\\s+repository\\s+=\\s+"(?<depName>.*?)"\\s+tag\\s+=\\s+"(?<currentValue>[\\w+\\.\\-]*)"'],
    },
    // Docker images defined in YAML manifests (Helm values).
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)*\\.yaml$/"],
      datasourceTemplate: "docker",
      matchStrings: ['\\s*repository:\\s+"*(?<depName>.*?)"*\\s*tag:\\s+"*(?<currentValue>[\\w+\\.\\-]*)(@(?<currentDigest>sha256:[a-f0-9]+))?"*'],
    },
    // Helm charts defined in Nix files.
    {
      customType: "regex",
      managerFilePatterns: ["/(^|/)*\\.nix$/"],
      datasourceTemplate: "helm",
      matchStrings: ['\\s*name\\s+=\\s+"*(?<depName>.*?)";*\\s*repo\\s+=\\s+"*(?<registryUrl>.*?)";*\\s*version\\s+=\\s+"*(?<currentValue>[\\w+\\.\\-]*)"*'],
    },
  ],
}
